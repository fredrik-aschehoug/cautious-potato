@page "/recipies"
@using CautiousPotato.Client.Features.Recipies
@using CautiousPotato.Client.Services
@using CauriousPotato.Requests.Recipies

<PageTitle>Recipies</PageTitle>


<FluentGrid Spacing="2" Style="padding: 8px;">
    <FluentGridItem xs="5">
        <FluentCard>
            <FluentStack Orientation="Orientation.Vertical">
                <FluentLabel>Add Recipe</FluentLabel>
                <EditForm Model="@FormModel" OnValidSubmit="@HandleValidSubmitAsync" FormName="recipe_entry">
                    <FluentStack HorizontalAlignment="HorizontalAlignment.Center">
                        <FluentTextField Name="name" @bind-Value="FormModel.Name" Label="Recipe name" Required />
                        <FluentButton Type="ButtonType.Submit" Appearance="Appearance.Accent">Submit</FluentButton>
                    </FluentStack>
                </EditForm>
            </FluentStack>
        </FluentCard>
    </FluentGridItem>
    <FluentGridItem xs="5">
        <RecipiesList />
    </FluentGridItem>
</FluentGrid>

@code {
    [Inject] public required IRecipiesService RecipiesService { get; set; }
    private Recipe[]? _recipies;

    [SupplyParameterFromForm]
    private RecipeFormModel FormModel { get; set; } = new();

    private async Task HandleValidSubmitAsync()
    {
        var request = new CreateRecipeRequest(FormModel.Name, []);
        await RecipiesService.CreateRecipeAsync(request);

        FormModel = new();
    }

    internal class RecipeFormModel
    {
        public string Name { get; set; } = "";
    }
}
